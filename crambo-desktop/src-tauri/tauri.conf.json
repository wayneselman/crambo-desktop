{
  "$schema": "https://raw.githubusercontent.com/nicegram/nicegram-tauri/refs/heads/develop/crates/tauri-utils/schema.json",
  "productName": "Crambo",
  "version": "0.1.0",
  "identifier": "com.crambo.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Crambo",
        "width": 800,
        "height": 600,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Crambo"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": null
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["crambo"]
      }
    },
    "shell": {
      "open": true
    }
  }
}
